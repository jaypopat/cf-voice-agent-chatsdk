{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": ["ultracite/biome/core", "ultracite/biome/vitest"],
  "linter": {
    "rules": {
      "style": {
        // Constructor parameter properties are the leanest idiomatic DI here;
        // immutability is still enforced via useReadonlyClassProperties.
        "noParameterProperties": "off"
      }
    }
  }
}
