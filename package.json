{
  "dependencies": {
    "@chat-adapter/telegram": "4.29.0",
    "@cloudflare/ai-utils": "^1.0.1",
    "@cloudflare/voice": "0.2.1",
    "agents": "^0.13.3",
    "chat": "4.29.0",
    "drizzle-orm": "^0.45.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@cloudflare/vitest-pool-workers": "^0.16.10",
    "@cloudflare/workers-types": "^4.20260529.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3",
    "ultracite": "7.8.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.0",
    "wrangler": "^4.95.0"
  },
  "name": "cf-voice-agent-chatsdk",
  "scripts": {
    "build:web": "vite build web",
    "test": "vitest run",
